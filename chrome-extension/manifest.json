{
  "manifest_version": 3,
  "name": "CHDS CRM — LinkedIn Capture",
  "version": "1.1.0",
  "description": "Save LinkedIn profiles directly to CH Digital Solutions CRM",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/in/*"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "action": {
    "default_popup": "popup.html"
  }
}
